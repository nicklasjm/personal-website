---
import type { BlueskyPost } from "@/lib/bluesky";

interface Props {
  post: BlueskyPost;
}

const { post } = Astro.props;

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString("en-GB", {
    day: "numeric",
    month: "short",
    year: "numeric",
  });
}

function formatCount(n: number): string {
  if (n >= 1000) return `${(n / 1000).toFixed(1)}k`;
  return String(n);
}

const imageCount = post.images?.length ?? 0;
---

<article class="bsky-post">
  {
    post.isReply && post.replyToHandle && (
      <p class="bsky-reply-indicator">
        <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
          <path
            d="M2 8 L2 4 Q2 2 4 2 L10 2"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"
          />
          <polyline
            points="8,0 10,2 8,4"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"
          />
        </svg>
        Reply to{" "}
        <a
          href={`https://bsky.app/profile/${post.replyToHandle}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          @{post.replyToHandle}
        </a>
      </p>
    )
  }

  <p class="bsky-text" set:html={post.textHtml} />

  {
    imageCount > 0 && (
      <div class:list={["bsky-images", `bsky-images--${Math.min(imageCount, 4)}`]}>
        {post.images!.slice(0, 4).map((img) => (
          <a
            href={img.fullsize}
            target="_blank"
            rel="noopener noreferrer"
            class="bsky-image-link"
          >
            <img src={img.thumb} alt={img.alt} loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
    )
  }

  {
    post.externalLink && (
      <a
        href={post.externalLink.uri}
        target="_blank"
        rel="noopener noreferrer"
        class="bsky-link-card"
      >
        {post.externalLink.thumb && (
          <img
            src={post.externalLink.thumb}
            alt=""
            loading="lazy"
            decoding="async"
            class="bsky-link-thumb"
          />
        )}
        <div class="bsky-link-meta">
          <span class="bsky-link-domain">
            {new URL(post.externalLink.uri).hostname.replace(/^www\./, "")}
          </span>
          {post.externalLink.title && (
            <span class="bsky-link-title">{post.externalLink.title}</span>
          )}
        </div>
      </a>
    )
  }

  {
    post.quotePost && (
      <a
        href={post.quotePost.url}
        target="_blank"
        rel="noopener noreferrer"
        class="bsky-quote"
      >
        <span class="bsky-quote-author">
          {post.quotePost.author.displayName ?? `@${post.quotePost.author.handle}`}
        </span>
        {post.quotePost.text && (
          <span class="bsky-quote-text">
            {post.quotePost.text.length > 140
              ? post.quotePost.text.slice(0, 140) + "…"
              : post.quotePost.text}
          </span>
        )}
      </a>
    )
  }

  <footer class="bsky-post-footer">
    <time class="bsky-date" datetime={post.createdAt}>{formatDate(post.createdAt)}</time>
    <div class="bsky-stats" aria-label="Engagement">
      {
        post.likeCount > 0 && (
          <span title="Likes">
            <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path
                d="M6 10.5 C6 10.5 1 7.5 1 4 A2.5 2.5 0 0 1 6 3.3 A2.5 2.5 0 0 1 11 4 C11 7.5 6 10.5 6 10.5Z"
                stroke="currentColor"
                stroke-width="1.25"
                stroke-linejoin="round"
                fill="none"
              />
            </svg>
            {formatCount(post.likeCount)}
          </span>
        )
      }
      {
        post.repostCount > 0 && (
          <span title="Reposts">
            <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path
                d="M2 4 L2 8 Q2 10 4 10 L8 10 M10 8 L10 4 Q10 2 8 2 L4 2"
                stroke="currentColor"
                stroke-width="1.25"
                stroke-linecap="round"
                fill="none"
              />
              <polyline
                points="8,6 10,8 8,10"
                stroke="currentColor"
                stroke-width="1.25"
                stroke-linecap="round"
                stroke-linejoin="round"
                fill="none"
              />
              <polyline
                points="4,0 2,2 4,4"
                stroke="currentColor"
                stroke-width="1.25"
                stroke-linecap="round"
                stroke-linejoin="round"
                fill="none"
              />
            </svg>
            {formatCount(post.repostCount)}
          </span>
        )
      }
      {
        post.replyCount > 0 && (
          <span title="Replies">
            <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path
                d="M1 2 Q1 1 2 1 L10 1 Q11 1 11 2 L11 7 Q11 8 10 8 L6.5 8 L4 11 L4 8 L2 8 Q1 8 1 7 Z"
                stroke="currentColor"
                stroke-width="1.25"
                stroke-linejoin="round"
                fill="none"
              />
            </svg>
            {formatCount(post.replyCount)}
          </span>
        )
      }
    </div>
    <a href={post.url} target="_blank" rel="noopener noreferrer" class="bsky-view-btn">
      View on Bluesky
    </a>
  </footer>
</article>

<style>
  .bsky-post {
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .bsky-post:last-child {
    border-bottom: none;
  }

  .bsky-reply-indicator {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: 0;
  }

  .bsky-reply-indicator svg {
    flex-shrink: 0;
  }

  .bsky-reply-indicator a {
    color: var(--color-accent);
  }

  .bsky-text {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-primary);
    margin-bottom: 0;
  }

  .bsky-text :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .bsky-text :global(a:hover) {
    text-decoration-thickness: 2px;
  }

  /* ── Images ── */
  .bsky-images {
    display: grid;
    gap: 3px;
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .bsky-images--1 {
    grid-template-columns: 1fr;
  }

  .bsky-images--2 {
    grid-template-columns: 1fr 1fr;
  }

  .bsky-images--3 {
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
  }

  .bsky-images--3 .bsky-image-link:first-child {
    grid-column: span 2;
  }

  .bsky-images--4 {
    grid-template-columns: 1fr 1fr;
  }

  .bsky-image-link {
    display: block;
    overflow: hidden;
    aspect-ratio: 16 / 10;
  }

  .bsky-image-link img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .bsky-image-link:hover img {
    transform: scale(1.02);
  }

  /* ── External link card ── */
  .bsky-link-card {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .bsky-link-card:hover {
    background: var(--nav-glass-hover);
    border-color: var(--color-accent);
  }

  .bsky-link-thumb {
    width: 48px;
    height: 48px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .bsky-link-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .bsky-link-domain {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .bsky-link-title {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-primary);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ── Quote post ── */
  .bsky-quote {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--space-sm);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    background: var(--color-bg-elevated);
    transition:
      background-color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .bsky-quote:hover {
    background: var(--nav-glass-hover);
    border-color: var(--color-accent);
  }

  .bsky-quote-author {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .bsky-quote-text {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
  }

  /* ── Footer ── */
  .bsky-post-footer {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .bsky-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .bsky-stats {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex: 1;
  }

  .bsky-stats span {
    display: flex;
    align-items: center;
    gap: 3px;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .bsky-view-btn {
    margin-left: auto;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    flex-shrink: 0;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .bsky-view-btn:hover {
    opacity: 0.75;
    color: var(--color-accent);
  }
</style>
