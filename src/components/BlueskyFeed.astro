---
import type { BlueskyPost } from "@/lib/bluesky";
import BlueskyPostCard from "./BlueskyPost.astro";

interface Props {
  posts: BlueskyPost[];
  handle: string;
}

const { posts, handle } = Astro.props;

// Nothing to render if no posts and no handle configured
if (posts.length === 0) return;
---

<section class="bsky-section animate-in" aria-label="Bluesky posts">
  <div class="bsky-section-inner">
    <div class="bsky-header">
      <div class="bsky-header-left">
        <!-- Bluesky butterfly mark -->
        <svg
          class="bsky-logo"
          viewBox="0 0 600 530"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
          focusable="false"
        >
          <path
            d="M135.72 44.03C202.216 93.951 273.74 195.17 300 249.49c26.262-54.316 97.782-155.54 164.28-205.46C512.26 8.009 590 -17.7 590 81.093c0 19.877-11.389 166.94-18.057 190.7-23.234 83.28-107.99 104.48-183.32 91.655 131.66 22.387 165.22 96.577 92.883 170.77-137.26 140.78-197.17-35.311-213.19-80.402-2.764-7.986-4.049-11.71-4.149-8.548-.1 3.163-1.385 6.887-4.149 8.548-16.021 45.091-75.928 221.18-213.19 80.402-72.338-74.195-38.781-148.38 92.883-170.77-75.329 12.826-160.08-8.374-183.32-91.655C21.389 248.04 10 101.97 10 81.093 10-17.7 87.74 8.009 135.72 44.03z"
          ></path>
        </svg>
        <div>
          <h2 class="bsky-section-title">Bluesky</h2>
          <a
            href={`https://bsky.app/profile/${handle}`}
            target="_blank"
            rel="noopener noreferrer"
            class="bsky-handle"
          >
            @{handle}
          </a>
        </div>
      </div>

      <button
        class="bsky-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="bsky-posts-list"
      >
        <span class="bsky-toggle-label">
          <span data-open="false">{posts.length} post{posts.length === 1 ? "" : "s"}</span>
        </span>
        <svg
          class="bsky-toggle-chevron"
          width="14"
          height="14"
          viewBox="0 0 14 14"
          aria-hidden="true"
        >
          <polyline
            points="2,5 7,10 12,5"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"
          ></polyline>
        </svg>
      </button>
    </div>

    <div id="bsky-posts-list" class="bsky-posts" hidden>
      {posts.map((post) => <BlueskyPostCard post={post} />)}
    </div>
  </div>
</section>

<style>
  .bsky-section {
    margin-top: var(--space-3xl);
  }

  .bsky-section-inner {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-elevated);
    overflow: hidden;
  }

  /* ── Header ── */
  .bsky-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    padding: var(--space-md) var(--space-lg);
  }

  .bsky-header-left {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .bsky-logo {
    width: 22px;
    height: 22px;
    fill: var(--bsky-color, hsl(211, 100%, 56%));
    flex-shrink: 0;
  }

  .bsky-section-title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    line-height: 1.2;
    margin-bottom: 2px;
  }

  .bsky-handle {
    display: block;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .bsky-handle:hover {
    color: var(--bsky-color, hsl(211, 100%, 56%));
  }

  /* ── Toggle button ── */
  .bsky-toggle {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 6px 12px;
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-secondary);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    cursor: pointer;
    white-space: nowrap;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .bsky-toggle:hover {
    color: var(--color-text-primary);
    border-color: var(--color-accent);
  }

  .bsky-toggle-chevron {
    flex-shrink: 0;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .bsky-toggle[aria-expanded="true"] .bsky-toggle-chevron {
    transform: rotate(180deg);
  }

  /* ── Posts list ── */
  .bsky-posts {
    padding: 0 var(--space-lg) var(--space-md);
    border-top: 1px solid var(--color-border);
  }

  .bsky-posts[hidden] {
    display: none;
  }

  /* ── Dark mode accent ── */
  :global([data-theme="dark"]) .bsky-logo {
    fill: hsl(211, 90%, 65%);
  }

  :global([data-theme="dark"]) .bsky-handle:hover {
    color: hsl(211, 90%, 65%);
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>(".bsky-toggle");
  const postsList = document.getElementById("bsky-posts-list");
  const label = toggle?.querySelector<HTMLElement>("[data-open]");

  if (toggle && postsList && label) {
    const totalText = label.textContent ?? "";

    toggle.addEventListener("click", () => {
      const isExpanded = toggle.getAttribute("aria-expanded") === "true";
      const next = !isExpanded;

      toggle.setAttribute("aria-expanded", String(next));
      postsList.hidden = !next;

      label.textContent = next ? "Hide posts" : totalText;
    });
  }
</script>
